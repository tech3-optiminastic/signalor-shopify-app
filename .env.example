# Shopify App Credentials (from Partners Dashboard)
SHOPIFY_API_KEY=your_client_id
SHOPIFY_API_SECRET=your_client_secret
SCOPES=read_products,write_products,read_content,write_content,read_metafields,write_metafields,read_themes,write_themes

# App URL (your deployed domain)
SHOPIFY_APP_URL=https://app.signalor.ai

# HMAC secret for Django → this app (/api/sync-session, /api/apply-fix).
# Use the same value as SIGNALOR_SHOPIFY_APP_HMAC_SECRET on the Signalor backend,
# or omit both and use Shopify API secret on both sides (SHOPIFY_CLIENT_SECRET / SHOPIFY_API_SECRET).
SIGNALOR_HMAC_SECRET=
# Optional alias matching backend env name (either this or SIGNALOR_HMAC_SECRET is enough):
# SIGNALOR_SHOPIFY_APP_HMAC_SECRET=

# Database
# Dev:  file:./dev.db
# Prod: postgresql://user:password@host:5432/signalor_shopify
DATABASE_URL=postgresql://user:password@host:5432/signalor_shopify
